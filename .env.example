# ============================================================================
# OkNexus Environment Configuration Template
# ============================================================================
# Copy this file to .env.local and fill in the actual values
# IMPORTANT: .env.local is in .gitignore and will NOT be committed to GitHub
# ============================================================================

# --- NextAuth Configuration ---
# Auto-generated during setup. Run: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET=your-secret-key-here-generate-a-new-one

# Your application URL
NEXTAUTH_URL=http://localhost:3000

# --- Zitadel OIDC Provider Configuration ---
# Zitadel is the identity provider for authentication

# Zitadel issuer URL (local development)
ZITADEL_ISSUER=http://localhost:8080

# Client ID from Zitadel Console
# To get this:
# 1. Start: docker compose up -d
# 2. Open: http://localhost:8080/ui/console
# 3. Login: admin / Admin@123!Change
# 4. Applications → Create New Application
# 5. Name: NextAuth, Type: Web
# 6. Copy the Client ID
ZITADEL_CLIENT_ID=your-client-id-from-zitadel-console

# Client Secret from Zitadel Console
# To get this:
# 1. In the NextAuth application in Zitadel
# 2. Go to Keys section
# 3. Generate or copy the Client Secret
ZITADEL_CLIENT_SECRET=your-client-secret-from-zitadel-console

# --- Supabase Configuration (Optional) ---
# If using Supabase for application data storage (separate from authentication)
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Development Settings ---
# NODE_ENV=development

# --- Optional: Additional Zitadel Configuration ---
# For production deployments, you may need:
# ZITADEL_ISSUER=https://your-zitadel-domain.com
# ZITADEL_TLS_ENABLED=true
# NEXTAUTH_URL=https://your-app-domain.com
